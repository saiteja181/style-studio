# Copy this file to .env and fill in real values.
# .env is gitignored and never committed.

# Replicate (image generation) - get at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Anthropic Claude (expert stylist consultant) - get at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: Supabase for catalogue + bill linking (Week 3+)
SUPABASE_URL=
SUPABASE_KEY=

# Server config
PORT=8000
HOST=127.0.0.1
LOG_LEVEL=info
